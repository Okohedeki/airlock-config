{
  "name": "airlock-config",
  "version": "0.5.0",
  "description": "The config file format that lets AI agents discover and integrate with your business — without prior coordination. Schema + open-source toolchain.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "airlock-config": "./dist/cli.js"
  },
  "files": [
    "dist",
    "schema"
  ],
  "scripts": {
    "build": "tsc && npm run build:playground",
    "build:playground": "esbuild src/playground/index.ts --bundle --format=iife --platform=browser --target=es2020 --minify --outfile=dist/playground.bundle.js",
    "dev": "tsx src/cli.ts",
    "test": "npm run build:playground && vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "Apache-2.0",
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "commander": "^12.1.0",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "esbuild": "^0.28.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  }
}
